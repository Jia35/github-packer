{
  "manifest_version": 3,
  "name": "Packer for GitHub",
  "version": "0.1.0",
  "description": "Selectively pick and pack files or folders from any GitHub repository into a single ZIP archive. Fast, secure, and supports private repositories.",
  "icons": {
    "16": "icons/logo_16.png",
    "32": "icons/logo_32.png",
    "48": "icons/logo_48.png",
    "128": "icons/logo_128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/logo_16.png",
      "32": "icons/logo_32.png",
      "48": "icons/logo_48.png",
      "128": "icons/logo_128.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/shared/auth.js",
        "src/shared/i18n.js",
        "src/shared/state.js",
        "src/shared/github.js",
        "src/shared/packager.js",
        "src/content/ui.js",
        "src/content/main.js"
      ],
      "css": [
        "src/content/styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ]
}
